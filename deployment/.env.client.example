# Limbo image tag built by the client compose file
LIMBO_IMAGE_NAME=teastore-limbo-client:latest

# TeaStore server address reachable from the client PC
TEASTORE_HOST=10.1.1.1
TEASTORE_PORT=8080

# Director connection target; leave as "loadgenerator" for the bundled client stack
LOADGEN_HOST=loadgenerator
LOADGEN_PORT=5000

# Director runtime settings
WORKLOAD_INTENSITY=low
WARMUP_SECS=30
MAX_THREADS=256
AUTO_START=1
